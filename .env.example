# Copy this file to .env and fill in real values for local development.
# Never commit the actual .env file -- it's already covered by .gitignore.

# Postgres connection string used for prediction logging and drift monitoring.
# Get this from your Render Postgres service's "Connect" tab.
DATABASE_URL=postgresql://username:password@host:5432/dbname

# Set automatically by Render in production. Only needed locally if you want
# to run the backend on a specific port; defaults to 10000 if unset.
PORT=8000
